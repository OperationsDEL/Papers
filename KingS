local function IsActive(imageId)
    local potionList = LocalPlayer.PlayerGui:WaitForChild("PotionList")

    for _, child in ipairs(potionList:GetChildren()) do
        if child:IsA("Frame") then
            for _, subChild in ipairs(child:GetChildren()) do
                if subChild:IsA("Frame") then
                    for _, last in ipairs(subChild:GetChildren()) do
                        if last:IsA("ImageLabel") and last.Image == imageId then
                            return true
                        end
                    end
                end
            end
        end
    end

    return false
end

local function FindCombatTool(container)
    for _, tool in ipairs(container:GetChildren()) do
        if tool:IsA("Tool") then
            local name = tool.Name:lower()
            if name:find("dao") or name:find("captain") then
                return tool
            end
        end
    end
end

local function FindSushiTool()
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            if tool.Name:lower():find("sushi") then
                return tool
            end
        end
    end
end

local function EquipTool(toolName)
    for i = 0, 7 do
        if LocalPlayer.Character:FindFirstChild(toolName) then
            break
        end
        LocalPlayer.ClientHotbarIndex.Value = i
        task.wait()
    end
end

local function EnsureCombatTool()
    local character = workspace:FindFirstChild(LocalPlayer.Name)

    if character then
        if FindCombatTool(character) then
            return
        end
    end

    local tool = FindCombatTool(LocalPlayer.Backpack)
    if tool then
        repeat
            EquipTool(tool.Name)
            task.wait()
        until character and FindCombatTool(character)
    end
end

