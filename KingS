local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local TARGET_IMAGE = "rbxassetid://7981378557"

local function CountBuffs()
	local count = 0

	local potionList = LocalPlayer.PlayerGui:WaitForChild("PotionList")

	for _, child in ipairs(potionList:GetChildren()) do
		if child:IsA("Frame") then
			for _, obj in ipairs(child:GetDescendants()) do
				if obj:IsA("ImageLabel") and obj.Image == TARGET_IMAGE then
					count += 1
				end
			end
		end
	end

	return count
end

local function EquipToolContains(word)
	word = word:lower()

	for slot = 0, 7 do
		LocalPlayer.ClientHotbarIndex.Value = slot
		task.wait()

		local character = LocalPlayer.Character
		if character then
			for _, tool in ipairs(character:GetChildren()) do
				if tool.Name:lower():find(word) then
					return tool
				end
			end
		end
	end

	return nil
end

local function HasEquippedToolContains(word)
	local character = workspace:FindFirstChild(LocalPlayer.Name)
	if not character then
		return false
	end

	word = word:lower()

	for _, child in ipairs(character:GetChildren()) do
		if child.Name:lower():find(word) then
			return true
		end
	end

	return false
end

while true do
	if CountBuffs() >= 2 and not HasEquippedToolContains("captain") then
