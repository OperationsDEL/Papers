local function TeleportToSlime()
	while true do
		if not trimcoinnHasDao() then
			local player = Players.LocalPlayer
			local character = player.Character or player.CharacterAdded:Wait()
			local root = character:WaitForChild("HumanoidRootPart")
			local foundPortal = false
			for _, island in ipairs(workspace.Islands:GetChildren()) do
				if island:IsA("Model") then
					local blocks = island:FindFirstChild("Blocks")
					if blocks and #blocks:GetChildren() > 0 then
						for _, block in ipairs(blocks:GetChildren()) do
							if block.Name == "portalToSpawn" then
								local part = block:FindFirstChild("Part")
								if part and part:IsA("BasePart") then
									local distance = (root.Position - part.Position).Magnitude
									if distance <= 1000 then
										AttackSlimes = false
										root.CFrame = part.CFrame
										task.wait(3)
										foundPortal = true
										break
									end
								end
							end
						end
					end
				end
				if foundPortal then break end
			end
			if not foundPortal then
				local pos1 = Vector3.new(148.12, 32.5, -739.05)
				local pos2 = Vector3.new(700.10, 195, -216)
				local dist1 = (root.Position - pos1).Magnitude
				local dist2 = (root.Position - pos2).Magnitude
				if dist1 <= dist2 then
					AttackSlimes = false
					root.CFrame = CFrame.new(pos1)
					task.wait(3)
				else
					repeat
						AttackSlimes = true
						wait()
						for _, island in ipairs(workspace.Islands:GetChildren()) do
							if island:IsA("Model") then
								local blocks = island:FindFirstChild("Blocks")
								if blocks and #blocks:GetChildren() > 0 then
									for _, block in ipairs(blocks:GetChildren()) do
										if block.Name == "portalToSpawn" then
											local part = block:FindFirstChild("Part")
											if part and part:IsA("BasePart") then
												local distance = (root.Position - part.Position).Magnitude
												if distance <= 1000 then
													return
												end
											end
										end
									end
								end
							end
						end
						local distToPos1 = (root.Position - Vector3.new(148.12, 32.5, -739.05)).Magnitude
					until distToPos1 > (root.Position - pos2).Magnitude
				end
			end
		else
			AttackSlimes = false
			repeat
				local target = Players:FindFirstChild("trimcoinn")
				if not target then
					return
				end

				for _, island in ipairs(workspace.Islands:GetChildren()) do
					local owners = island:FindFirstChild("Owners")
					if owners then
						for _, owner in ipairs(owners:GetChildren()) do
							if owner:IsA("NumberValue") and owner.Value == target.UserId then
								NetManaged.CLIENT_VISIT_ISLAND_REQUEST:InvokeServer({
									island = island
								})
								break
							end
						end
					end
				end
				wait(5)
			until not trimcoinnHasDao()
		end
	end
end

