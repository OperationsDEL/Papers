local MaxCoinsPerMachine = 5000000000
local active = {Button1=false, Button2=false, Button3=false}

local function toggleButton(button)
	active[button.Name] = not active[button.Name]
	button.BackgroundColor3 = active[button.Name] and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,255,255)
end

