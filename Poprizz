Button3.MouseButton1Click:Connect(function()
	toggleButton(Button3)
	if active.Button3 then
		Islands = getClosestIsland()
	end
	task.spawn(function()
		while active.Button3 do
			if not Islands then
				Islands = getClosestIsland()
			end
			local vending = getClosestVending(Islands)
			if vending then
				local bal = vending.CoinBalance.Value
				if bal < 4500000000 then
					fillVendingMachine(vending,1500000000)
				elseif bal < 5000000000 then
					fillVendingMachine(vending,500000000)
				end
			end
			task.wait()
		end
	end)
end)
